@model Hackathon1.Models.ViewModels.CitizenDashboardViewModel
@{
    ViewData["Title"] = "Mi Dashboard";
}

<div class="container py-4">
    <h2 class="mb-4">Bienvenido/a, @(Model.User.FullName ?? Model.User.UserName)</h2>

    <div class="row g-4">
        <!-- Perfil del ciudadano -->
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-person-fill"></i> Mi Perfil</h5>
                </div>
                <div class="card-body">
                    <p><strong>Provincia:</strong> @(string.IsNullOrEmpty(Model.User.Provincia) ? "No especificada" : Model.User.Provincia)</p>
                    <p><strong>Tipo de vivienda:</strong> @(string.IsNullOrEmpty(Model.User.TipoVivienda) ? "No especificado" : Model.User.TipoVivienda)</p>
                    @if (!string.IsNullOrEmpty(Model.User.NecesidadesEspeciales))
                    {
                        <p><strong>Necesidades especiales:</strong> @Model.User.NecesidadesEspeciales</p>
                    }
                    <a asp-controller="Citizen" asp-action="Profile" class="btn btn-outline-primary btn-sm mt-2">Editar perfil</a>
                </div>
            </div>
        </div>

        <!-- Previsión meteorológica -->
        <div class="col-md-8">
            <div class="card h-100 shadow-sm">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0"><i class="bi bi-cloud-sun-fill"></i> Previsión para @Model.Forecast.Provincia — @Model.Forecast.Fecha.ToString("dd/MM/yyyy")</h5>
                </div>
                <div class="card-body">
                    <div class="row row-cols-2 row-cols-sm-3 g-3">
                        <div class="col">
                            <div class="border rounded p-2 text-center">
                                <div class="text-muted small">Tmax</div>
                                <div class="fs-5 fw-bold">@Model.Forecast.Tmax °C</div>
                                <div class="text-muted small">(@Model.Forecast.HoraTmax)</div>
                            </div>
                        </div>
                        <div class="col">
                            <div class="border rounded p-2 text-center">
                                <div class="text-muted small">Tmin</div>
                                <div class="fs-5 fw-bold">@Model.Forecast.Tmin °C</div>
                                <div class="text-muted small">(@Model.Forecast.HoraTmin)</div>
                            </div>
                        </div>
                        <div class="col">
                            <div class="border rounded p-2 text-center">
                                <div class="text-muted small">Tmed</div>
                                <div class="fs-5 fw-bold">@Model.Forecast.Tmed °C</div>
                            </div>
                        </div>
                        <div class="col">
                            <div class="border rounded p-2 text-center">
                                <div class="text-muted small">Precipitación</div>
                                <div class="fs-5 fw-bold">@Model.Forecast.Prec mm</div>
                            </div>
                        </div>
                        <div class="col">
                            <div class="border rounded p-2 text-center">
                                <div class="text-muted small">Humedad media</div>
                                <div class="fs-5 fw-bold">@Model.Forecast.HrMedia %</div>
                            </div>
                        </div>
                        <div class="col">
                            <div class="border rounded p-2 text-center">
                                <div class="text-muted small">Racha máx.</div>
                                <div class="fs-5 fw-bold">@Model.Forecast.Racha km/h</div>
                                <div class="text-muted small">(@Model.Forecast.Horaracha)</div>
                            </div>
                        </div>
                        <div class="col">
                            <div class="border rounded p-2 text-center">
                                <div class="text-muted small">Vel. media viento</div>
                                <div class="fs-5 fw-bold">@Model.Forecast.Velmedia km/h</div>
                            </div>
                        </div>
                        <div class="col">
                            <div class="border rounded p-2 text-center">
                                <div class="text-muted small">Dirección viento</div>
                                <div class="fs-5 fw-bold">@Model.Forecast.Dir</div>
                            </div>
                        </div>
                        <div class="col">
                            <div class="border rounded p-2 text-center">
                                <div class="text-muted small">Horas de sol</div>
                                <div class="fs-5 fw-bold">@Model.Forecast.Sol h</div>
                            </div>
                        </div>
                        <div class="col">
                            <div class="border rounded p-2 text-center">
                                <div class="text-muted small">Pres. máx.</div>
                                <div class="fs-5 fw-bold">@Model.Forecast.PresMax hPa</div>
                                <div class="text-muted small">(@Model.Forecast.HoraPresMax)</div>
                            </div>
                        </div>
                        <div class="col">
                            <div class="border rounded p-2 text-center">
                                <div class="text-muted small">Pres. mín.</div>
                                <div class="fs-5 fw-bold">@Model.Forecast.PresMin hPa</div>
                                <div class="text-muted small">(@Model.Forecast.HoraPresMin)</div>
                            </div>
                        </div>
                        @if (Model.Forecast.Altitud.HasValue)
                        {
                            <div class="col">
                                <div class="border rounded p-2 text-center">
                                    <div class="text-muted small">Altitud</div>
                                    <div class="fs-5 fw-bold">@Model.Forecast.Altitud m</div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Recomendaciones -->
    @if (Model.Recommendations.Any())
    {
        <div class="row mt-4">
            <div class="col">
                <div class="card shadow-sm border-warning">
                    <div class="card-header bg-warning text-dark">
                        <h5 class="mb-0"><i class="bi bi-exclamation-triangle-fill"></i> Recomendaciones</h5>
                    </div>
                    <ul class="list-group list-group-flush">
                        @foreach (var rec in Model.Recommendations)
                        {
                            <li class="list-group-item">
                                <i class="bi bi-check2-circle text-warning me-2"></i>@rec
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </div>
    }
</div>
