# Bearer token from the hackathon API (/register + /login)
VITE_BEARER_TOKEN=

# Weather mode for /weather endpoint
# false = normal weather, true = disaster simulation
VITE_WEATHER_DISASTER_MODE=false

# Supabase project credentials
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# Google OAuth (configured in Supabase Dashboard > Auth > Providers)
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_SECRET=
SUPABASE_AUTH_EXTERNAL_GOOGLE_REDIRECT_URI=

# Supabase Postgres password (for direct DB access if needed)
SUPABASE_POSTGRES_PASSWORD=
